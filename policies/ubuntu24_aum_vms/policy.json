{
  "id": "/providers/Microsoft.Management/managementGroups/e2995d11-9947-4e78-9de6-d44e0603518e/providers/Microsoft.Authorization/policyDefinitions/CppUbuntuAumVMsAssessmentOnly",
  "name": "CppUbuntuAumVMsAssessmentOnly",
  "properties": {
    "description": "Configure Azure Update Manager periodic assessment (scan) for Canonical Ubuntu Azure VMs by enforcing osProfile.linuxConfiguration.patchSettings.assessmentMode = AutomaticByPlatform.",
    "displayName": "Configure Azure Update Manager periodic assessment for Ubuntu (Canonical) VMs (assessment only)",
    "metadata": {
      "category": "Update Management",
      "notes": [
        "JSON does not support comments; documentation is stored in metadata.notes.",
        "Targets Marketplace Ubuntu images via storageProfile.imageReference.publisher == Canonical (case-insensitive) AND offer like '*ubuntu*'.",
        "Remediation sets only osProfile.linuxConfiguration.patchSettings.assessmentMode to avoid enforcing patchMode/reboot settings.",
        "Use excludedResourceNamePatterns to opt out specific VMs by name if required."
      ],
      "version": "1.0.0"
    },
    "mode": "Indexed",
    "parameters": {
      "effect": {
        "allowedValues": [
          "DeployIfNotExists",
          "Disabled"
        ],
        "defaultValue": "DeployIfNotExists",
        "metadata": {
          "description": "Deploys the configuration when it is missing or misconfigured.",
          "displayName": "Effect"
        },
        "type": "String"
      },
      "excludedResourceNamePatterns": {
        "defaultValue": [],
        "metadata": {
          "description": "Optional list of VM name patterns to exclude. Supports '*' wildcards. Empty array means no exclusions.",
          "displayName": "Excluded VM name patterns"
        },
        "type": "Array"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "equals": "Microsoft.Compute/virtualMachines",
            "field": "type"
          },
          {
            "field": "Microsoft.Compute/virtualMachines/storageProfile.imageReference.publisher",
            "in": [
              "Canonical",
              "canonical"
            ]
          },
          {
            "contains": "ubuntu",
            "field": "Microsoft.Compute/virtualMachines/storageProfile.imageReference.offer"
          },
          {
            "not": {
              "count": {
                "name": "pattern",
                "value": "[parameters('excludedResourceNamePatterns')]",
                "where": {
                  "field": "name",
                  "like": "[current('pattern')]"
                }
              },
              "greater": 0
            }
          }
        ]
      },
      "then": {
        "details": {
          "deployment": {
            "properties": {
              "mode": "incremental",
              "parameters": {
                "location": {
                  "value": "[field('location')]"
                },
                "vmName": {
                  "value": "[field('name')]"
                }
              },
              "template": {
                "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
                "contentVersion": "1.0.0.0",
                "parameters": {
                  "location": {
                    "type": "string"
                  },
                  "vmName": {
                    "type": "string"
                  }
                },
                "resources": [
                  {
                    "apiVersion": "2022-11-01",
                    "location": "[parameters('location')]",
                    "name": "[parameters('vmName')]",
                    "properties": {
                      "osProfile": {
                        "linuxConfiguration": {
                          "patchSettings": {
                            "assessmentMode": "AutomaticByPlatform"
                          }
                        }
                      }
                    },
                    "type": "Microsoft.Compute/virtualMachines"
                  }
                ]
              }
            }
          },
          "existenceCondition": {
            "allOf": [
              {
                "equals": "AutomaticByPlatform",
                "field": "Microsoft.Compute/virtualMachines/osProfile.linuxConfiguration.patchSettings.assessmentMode"
              }
            ]
          },
          "roleDefinitionIds": [
            "/providers/microsoft.authorization/roleDefinitions/9980e02c-c2be-4d73-94e8-173b1dc7cf3c"
          ],
          "type": "Microsoft.Compute/virtualMachines"
        },
        "effect": "[parameters('effect')]"
      }
    },
    "policyType": "Custom"
  }
}
