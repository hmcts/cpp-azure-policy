{
  "id": "/providers/Microsoft.Management/managementGroups/e2995d11-9947-4e78-9de6-d44e0603518e/providers/Microsoft.Authorization/policyDefinitions/CppUbuntuAumVMSSAssessmentOnly",
  "name": "CppUbuntuAumVMSSAssessmentOnly",
  "properties": {
    "description": "Configure Azure Update Manager periodic assessment (scan) for Canonical Ubuntu Uniform VMSS by enforcing patchSettings.assessmentMode = AutomaticByPlatform.",
    "displayName": "Configure Azure Update Manager periodic assessment for Ubuntu (Canonical) Uniform VMSS (assessment only)",
    "metadata": {
      "category": "Update Management",
      "notes": [
        "Targets Uniform VMSS only (orchestrationMode Uniform or missing).",
        "Targets Marketplace Ubuntu images via imageReference.publisher == Canonical (case-insensitive) AND offer like '*ubuntu*'.",
        "Remediation sets only virtualMachineProfile.osProfile.linuxConfiguration.patchSettings.assessmentMode."
      ],
      "version": "1.0.0"
    },
    "mode": "All",
    "parameters": {
      "effect": {
        "allowedValues": [
          "DeployIfNotExists",
          "Disabled"
        ],
        "defaultValue": "DeployIfNotExists",
        "metadata": {
          "description": "Deploys the configuration when it is missing or misconfigured.",
          "displayName": "Effect"
        },
        "type": "String"
      },
      "excludedResourceNamePatterns": {
        "defaultValue": [],
        "metadata": {
          "description": "Optional list of VMSS name patterns to exclude. Supports '*' wildcards. Empty array means no exclusions.",
          "displayName": "Excluded VMSS name patterns"
        },
        "type": "Array"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "equals": "Microsoft.Compute/virtualMachineScaleSets",
            "field": "type"
          },
          {
            "anyOf": [
              {
                "equals": "Uniform",
                "field": "Microsoft.Compute/virtualMachineScaleSets/orchestrationMode"
              },
              {
                "exists": "false",
                "field": "Microsoft.Compute/virtualMachineScaleSets/orchestrationMode"
              }
            ]
          },
          {
            "field": "Microsoft.Compute/virtualMachineScaleSets/virtualMachineProfile.storageProfile.imageReference.publisher",
            "in": [
              "Canonical",
              "canonical"
            ]
          },
          {
            "contains": "ubuntu",
            "field": "Microsoft.Compute/virtualMachineScaleSets/virtualMachineProfile.storageProfile.imageReference.offer"
          },
          {
            "not": {
              "count": {
                "name": "pattern",
                "value": "[parameters('excludedResourceNamePatterns')]",
                "where": {
                  "field": "name",
                  "like": "[current('pattern')]"
                }
              },
              "greater": 0
            }
          }
        ]
      },
      "then": {
        "details": {
          "deployment": {
            "properties": {
              "evaluationDelay": "AfterProvisioningSuccess",
              "mode": "incremental",
              "parameters": {
                "location": {
                  "value": "[field('location')]"
                },
                "vmssName": {
                  "value": "[field('name')]"
                }
              },
              "template": {
                "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
                "contentVersion": "1.0.0.0",
                "parameters": {
                  "location": {
                    "type": "string"
                  },
                  "vmssName": {
                    "type": "string"
                  }
                },
                "resources": [
                  {
                    "apiVersion": "2024-03-01",
                    "location": "[parameters('location')]",
                    "name": "[parameters('vmssName')]",
                    "properties": {
                      "virtualMachineProfile": {
                        "osProfile": {
                          "linuxConfiguration": {
                            "patchSettings": {
                              "assessmentMode": "AutomaticByPlatform"
                            }
                          }
                        }
                      }
                    },
                    "type": "Microsoft.Compute/virtualMachineScaleSets"
                  }
                ]
              }
            }
          },
          "existenceCondition": {
            "allOf": [
              {
                "equals": "AutomaticByPlatform",
                "field": "Microsoft.Compute/virtualMachineScaleSets/virtualMachineProfile.osProfile.linuxConfiguration.patchSettings.assessmentMode"
              },
              {
                "field": "Microsoft.Compute/virtualMachineScaleSets/virtualMachineProfile.osProfile.linuxConfiguration.patchSettings.patchMode",
                "in": [
                  "ImageDefault",
                  "CustomerManagedSchedules"
                ]
              }
            ]
          },
          "name": "[field('name')]",
          "roleDefinitionIds": [
            "/providers/microsoft.authorization/roleDefinitions/9980e02c-c2be-4d73-94e8-173b1dc7cf3c"
          ],
          "type": "Microsoft.Compute/virtualMachineScaleSets"
        },
        "effect": "[parameters('effect')]"
      }
    },
    "policyType": "Custom"
  }
}
